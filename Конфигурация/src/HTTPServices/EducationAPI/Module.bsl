Функция statusGetStatus(HTTPЗапрос)
	
	ОшибкаДоступа = ПроверитьДоступИВернутьОшибку(HTTPЗапрос);
	Если ОшибкаДоступа <> Неопределено Тогда
		Возврат ОшибкаДоступа;
	КонецЕсли;

	Данные = Новый Структура;
	Данные.Вставить("service", "EducationAPI");
	Данные.Вставить("status", "running");
	Данные.Вставить("version", "1.0");
	Данные.Вставить("description", "Web-сервис системы управления образовательным процессом");

	Возврат СоздатьОтветСДанными(Данные);
	
КонецФункции

Функция СоздатьОтветСОшибкой(ТекстОшибки, КодСостояния = 400)

	ТелоОтвета = РаботаСJSONСервер.СформироватьОтветСОшибкой(ТекстОшибки, КодСостояния);
	Возврат СоздатьОтветJSON(ТелоОтвета, КодСостояния);

КонецФункции

Функция ПроверитьДоступИВернутьОшибку(HTTPЗапрос)

	Если ПроверкаДоступаAPISервер.ДоступРазрешен(HTTPЗапрос) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат СоздатьОтветСОшибкой("Доступ к API запрещен", 401);

КонецФункции

Функция СоздатьОтветJSON(ТелоJSON, КодСостояния = 200)

	HTTPОтвет = Новый HTTPСервисОтвет(КодСостояния);
	HTTPОтвет.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	HTTPОтвет.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);

	Возврат HTTPОтвет;

КонецФункции