
Функция scheduleGetSchedule(HTTPЗапрос)
	
	ОшибкаДоступа = ПроверитьДоступИВернутьОшибку(HTTPЗапрос);
	Если ОшибкаДоступа <> Неопределено Тогда
		Возврат ОшибкаДоступа;
	КонецЕсли;

	Попытка
		Данные = РаботаСWebAPISервер.ПолучитьРасписание();
		Возврат СоздатьОтветСДанными(Данные);
	Исключение
		Возврат СоздатьОтветСОшибкой(ОписаниеОшибки(), 500);
	КонецПопытки;
	
КонецФункции

