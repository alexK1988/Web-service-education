		Если ЗначениеЗаполнено(Направление) Тогда
			Элемент.НаправлениеПодготовки = Направление;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ФормаОбучения) Тогда
			Элемент.ФормаОбучения = ФормаОбучения;
		КонецЕсли;
		
		Элемент.Записать();
		
	КонецЦикла;

