Функция СоздатьОрганизацию()

	Ссылка = НайтиИлиСоздатьОрганизацию("Московский университет имени С.Ю. Витте");

	Возврат Ссылка;

КонецФункции

Функция НайтиИлиСоздатьОрганизацию(Наименование)

	Ссылка = Справочники.Организации.НайтиПоНаименованию(Наименование);

	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ссылка;
	КонецЕсли;

	Элемент = Справочники.Организации.СоздатьЭлемент();
	Элемент.Наименование = Наименование;
	Элемент.ПолноеНаименование = Наименование;
	Элемент.ИНН = "7701000000";
	Элемент.КПП = "770101001";
	Элемент.ЮридическийАдрес = "г. Москва, учебный корпус";
	Элемент.Телефон = "+7 495 123-21-12";
	Элемент.Email = "Vitte@example.ru";
	Элемент.Записать();

	Возврат Элемент.Ссылка;

КонецФункции

