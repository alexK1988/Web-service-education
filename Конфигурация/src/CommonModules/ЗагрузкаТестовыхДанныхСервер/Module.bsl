Процедура СоздатьПричинуОтсутствия(Наименование, Уважительная, ТребуетДокумент)

	Если ЗначениеЗаполнено(Справочники.ПричиныОтсутствия.НайтиПоНаименованию(Наименование)) Тогда
		Возврат;
	КонецЕсли;

	Элемент = Справочники.ПричиныОтсутствия.СоздатьЭлемент();
	Элемент.Наименование = Наименование;
	Элемент.Уважительная = Уважительная;
	Элемент.ТребуетДокумент = ТребуетДокумент;
	Элемент.Описание = "Тестовая причина отсутствия: " + Наименование;
	Элемент.Записать();

