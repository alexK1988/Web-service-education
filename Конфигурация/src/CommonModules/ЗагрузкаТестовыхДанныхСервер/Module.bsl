Процедура УдалитьЭлементыСправочника(МенеджерСправочника)

	// Делаем несколько проходов, потому что у иерархических справочников
	// сначала должны удалиться элементы, а потом группы.
	Для ПопыткаУдаления = 1 По 5 Цикл
		
		Выборка = МенеджерСправочника.Выбрать();
		ЕстьОшибки = Ложь;
		
		Пока Выборка.Следующий() Цикл
			
			Попытка
				Объект = Выборка.ПолучитьОбъект();
				Объект.Удалить();
			Исключение
				ЕстьОшибки = Истина;
			КонецПопытки;
			
		КонецЦикла;
		
		Если НЕ ЕстьОшибки Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры
