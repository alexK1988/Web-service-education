КонецПроцедуры

Процедура СоздатьНастройкиДоступаAPI()

	Выборка = Справочники.ВнешниеСистемы.Выбрать();

	Пока Выборка.Следующий() Цикл
		
		НаборЗаписей = РегистрыСведений.НастройкиДоступаAPI.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ВнешняяСистема.Установить(Выборка.Ссылка);
		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Запись = НаборЗаписей.Добавить();
		Запись.ВнешняяСистема = Выборка.Ссылка;
		Запись.ТокенДоступа = "token-" + Строка(Выборка.Код) + "-2026";
		Запись.РазрешитьЧтение = Истина;
		Запись.РазрешитьЗапись = Ложь;
		Запись.Активна = Истина;
		
		НаборЗаписей.Записать();
		
	КонецЦикла;

КонецПроцедуры

