Процедура СоздатьФормуОбучения(Наименование, Описание)

	Если ЗначениеЗаполнено(Справочники.ФормыОбучения.НайтиПоНаименованию(Наименование)) Тогда
		Возврат;
	КонецЕсли;

	Элемент = Справочники.ФормыОбучения.СоздатьЭлемент();
	Элемент.Наименование = Наименование;
	Элемент.Описание = Описание;
	Элемент.Используется = Истина;
	Элемент.Записать();

КонецПроцедуры