Процедура СоздатьУчебныеПериоды()

	Для Номер = 1 По 10 Цикл
		
		Наименование = "Семестр " + Строка(Номер);
		
		Если ЗначениеЗаполнено(Справочники.УчебныеПериоды.НайтиПоНаименованию(Наименование)) Тогда
			Продолжить;
		КонецЕсли;
		
		Элемент = Справочники.УчебныеПериоды.СоздатьЭлемент();
		Элемент.Наименование = Наименование;
		Элемент.ДатаНачала = Дата(2026, 1, 1) + (Номер - 1) * 15552000;
		Элемент.ДатаОкончания = Элемент.ДатаНачала + 12960000;
		Элемент.НомерСеместра = Номер;
		Элемент.Текущий = (Номер = 1);
		Элемент.Записать();
		
	КонецЦикла;

КонецПроцедуры

