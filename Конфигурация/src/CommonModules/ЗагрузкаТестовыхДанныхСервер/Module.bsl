		Кафедра = НайтиСправочникПоНаименованию(Справочники.Кафедры, Данные.Кафедра);

		Элемент = Справочники.Дисциплины.СоздатьЭлемент();
		Элемент.Наименование = Данные.Наименование;
		
		Если ЗначениеЗаполнено(Кафедра) Тогда
			Элемент.Кафедра = Кафедра;
		КонецЕсли;
		
		Элемент.КодДисциплины = Данные.КодДисциплины;
		Элемент.КоличествоЧасов = СтрокаВЧисло(Данные.КоличествоЧасов);
		Элемент.ЗачетныеЕдиницы = СтрокаВЧисло(Данные.ЗачетныеЕдиницы);
		Элемент.Активна = СтрокаВБулево(Данные.Активна);
		Элемент.Записать();
		
	КонецЦикла;

КонецПроцедуры

