Процедура ЗагрузитьСтудентовИзМакета(Макет)

	Строки = ПолучитьСтрокиРазделаМакета(Макет, "Студенты");

	Для Каждого Данные Из Строки Цикл
		
		Если ЗначениеЗаполнено(Справочники.Студенты.НайтиПоНаименованию(Данные.Наименование)) Тогда
			Продолжить;
		КонецЕсли;

		УчебнаяГруппа = НайтиСправочникПоНаименованию(Справочники.УчебныеГруппы, Данные.УчебнаяГруппа);
		ФормаОбучения = НайтиСправочникПоНаименованию(Справочники.ФормыОбучения, Данные.ФормаОбучения);

		Элемент = Справочники.Студенты.СоздатьЭлемент();
		Элемент.Наименование = Данные.Наименование;
		Элемент.Фамилия = Данные.Фамилия;
		Элемент.ИмяСтудента = Данные.ИмяСтудента;
		Элемент.Отчество = Данные.Отчество;
		Элемент.ДатаРождения = СтрокаВДату(Данные.ДатаРождения);
		
		Если ЗначениеЗаполнено(УчебнаяГруппа) Тогда
			Элемент.УчебнаяГруппа = УчебнаяГруппа;
		КонецЕсли;
		
		Элемент.НомерЗачетнойКнижки = Данные.НомерЗачетнойКнижки;
		Элемент.Телефон = Данные.Телефон;
		Элемент.Email = Данные.Email;
		Элемент.Статус = ПолучитьСтатусСтудента(Данные.Статус);
		
		Если ЗначениеЗаполнено(ФормаОбучения) Тогда
			Элемент.ФормаОбучения = ФормаОбучения;
		КонецЕсли;
		
		Элемент.Записать();
		
	КонецЦикла;

КонецПроцедуры

Функция ПолучитьСтатусСтудента(СтатусСтрокой)

	СтатусСтрокой = СокрЛП(Строка(СтатусСтрокой));

	Если СтатусСтрокой = "АкадемическийОтпуск" Или СтатусСтрокой = "Академический отпуск" Тогда
		Возврат Перечисления.СтатусыСтудента.АкадемическийОтпуск;
	КонецЕсли;

	Если СтатусСтрокой = "Отчислен" Тогда
		Возврат Перечисления.СтатусыСтудента.Отчислен;
	КонецЕсли;

	Если СтатусСтрокой = "Выпускник" Тогда
		Возврат Перечисления.СтатусыСтудента.Выпускник;
	КонецЕсли;

	Возврат Перечисления.СтатусыСтудента.Обучается;

КонецФункции

