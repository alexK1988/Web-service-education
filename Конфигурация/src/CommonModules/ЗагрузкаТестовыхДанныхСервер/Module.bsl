Функция ПолучитьСтрокиРазделаМакета(Макет, ИмяРаздела)

	Результат = Новый Массив;

	МаркерНачала = "#" + ИмяРаздела;
	МаркерКонца = "#Конец";

	НомерНачала = 0;
	НомерКонца = 0;

	Для НомерСтроки = 1 По Макет.ВысотаТаблицы Цикл
		
		ЗначениеЯчейки = СокрЛП(Строка(Макет.Область(НомерСтроки, 1).Текст));
		
		Если ЗначениеЯчейки = МаркерНачала Тогда
			
			НомерНачала = НомерСтроки;
			
			Для НомерСтрокиКонца = НомерСтроки + 1 По Макет.ВысотаТаблицы Цикл
				
				ЗначениеЯчейкиКонца = СокрЛП(Строка(Макет.Область(НомерСтрокиКонца, 1).Текст));
				
				Если ЗначениеЯчейкиКонца = МаркерКонца Тогда
					НомерКонца = НомерСтрокиКонца;
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;

	Если НомерНачала = 0 Или НомерКонца = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	СтрокаЗаголовков = НомерНачала + 1;
	Заголовки = Новый Массив;

	Для НомерКолонки = 1 По Макет.ШиринаТаблицы Цикл
		
		ИмяКолонки = СокрЛП(Строка(Макет.Область(СтрокаЗаголовков, НомерКолонки).Текст));
		
		Если ПустаяСтрока(ИмяКолонки) Тогда
			Прервать;
		КонецЕсли;
		
		Заголовки.Добавить(ИмяКолонки);
		
	КонецЦикла;

	Для НомерСтроки = НомерНачала + 2 По НомерКонца - 1 Цикл
		
		ДанныеСтроки = Новый Структура;
		ЕстьДанные = Ложь;

		Для ИндексКолонки = 0 По Заголовки.Количество() - 1 Цикл
			
			НомерКолонки = ИндексКолонки + 1;
			ИмяКолонки = Заголовки[ИндексКолонки];
			ЗначениеЯчейки = СокрЛП(Строка(Макет.Область(НомерСтроки, НомерКолонки).Текст));
			
			Если НЕ ПустаяСтрока(ЗначениеЯчейки) Тогда
				ЕстьДанные = Истина;
			КонецЕсли;
			
			ДанныеСтроки.Вставить(ИмяКолонки, ЗначениеЯчейки);
			
		КонецЦикла;

		Если ЕстьДанные Тогда
			Результат.Добавить(ДанныеСтроки);
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция СтрокаВБулево(ЗначениеСтрокой)

	ЗначениеСтрокой = ВРег(СокрЛП(Строка(ЗначениеСтрокой)));

	Возврат ЗначениеСтрокой = "ИСТИНА"
		Или ЗначениеСтрокой = "ДА"
		Или ЗначениеСтрокой = "1"
		Или ЗначениеСтрокой = "TRUE";

КонецФункции

Функция СтрокаВЧисло(ЗначениеСтрокой)

	ЗначениеСтрокой = СокрЛП(Строка(ЗначениеСтрокой));

	Если ПустаяСтрока(ЗначениеСтрокой) Тогда
		Возврат 0;
	КонецЕсли;

	Возврат Число(СтрЗаменить(ЗначениеСтрокой, ".", ","));

КонецФункции

Функция СтрокаВДату(ЗначениеСтрокой)

	ЗначениеСтрокой = СокрЛП(Строка(ЗначениеСтрокой));

	Если ПустаяСтрока(ЗначениеСтрокой) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЧастиДаты = СтрРазделить(ЗначениеСтрокой, ".");

	Если ЧастиДаты.Количество() <> 3 Тогда
		Возврат Неопределено;
	КонецЕсли;

	День = Число(ЧастиДаты[0]);
	Месяц = Число(ЧастиДаты[1]);
	Год = Число(ЧастиДаты[2]);

	Возврат Дата(Год, Месяц, День);

КонецФункции

Функция НайтиСправочникПоНаименованию(МенеджерСправочника, Наименование)

	Наименование = СокрЛП(Строка(Наименование));

	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Ссылка = МенеджерСправочника.НайтиПоНаименованию(Наименование);

	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ссылка;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

