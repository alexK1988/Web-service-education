Процедура УдалитьДокументыМенеджера(МенеджерДокумента)

	Выборка = МенеджерДокумента.Выбрать();

	Пока Выборка.Следующий() Цикл
		
		Попытка
			Объект = Выборка.ПолучитьОбъект();
			Объект.Удалить();
		Исключение
			Сообщить("Не удалось удалить документ: " + Строка(Выборка.Ссылка) + ". " + ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;

