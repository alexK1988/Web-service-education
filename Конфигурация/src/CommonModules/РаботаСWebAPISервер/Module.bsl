Функция ПолучитьСтудентов() Экспорт
	
	МассивСтудентов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Студенты.Ссылка КАК Ссылка,
	|	Студенты.Код КАК Код,
	|	Студенты.Наименование КАК Наименование,
	|	Студенты.Фамилия КАК Фамилия,
	|	Студенты.ИмяСтудента КАК ИмяСтудента,
	|	Студенты.Отчество КАК Отчество,
	|	Студенты.УчебнаяГруппа КАК УчебнаяГруппа,
	|	Студенты.НомерЗачетнойКнижки КАК НомерЗачетнойКнижки,
	|	Студенты.Email КАК Email,
	|	Студенты.Статус КАК Статус
	|ИЗ
	|	Справочник.Студенты КАК Студенты";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Студент = Новый Структура;
		Студент.Вставить("id", Строка(Выборка.Ссылка.УникальныйИдентификатор()));
		Студент.Вставить("code", Выборка.Код);
		Студент.Вставить("name", Выборка.Наименование);
		Студент.Вставить("last_name", Выборка.Фамилия);
		Студент.Вставить("first_name", Выборка.ИмяСтудента);
		Студент.Вставить("middle_name", Выборка.Отчество);
		Студент.Вставить("group", Строка(Выборка.УчебнаяГруппа));
		Студент.Вставить("record_book", Выборка.НомерЗачетнойКнижки);
		Студент.Вставить("email", Выборка.Email);
		Студент.Вставить("status", Строка(Выборка.Статус));
		
		МассивСтудентов.Добавить(Студент);
		
	КонецЦикла;
	
	Возврат МассивСтудентов;
	
КонецФункции

