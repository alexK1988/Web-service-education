Функция ПолучитьРасписание() Экспорт
	
	МассивРасписания = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасписаниеЗанятий.УчебнаяГруппа КАК УчебнаяГруппа,
	|	РасписаниеЗанятий.Дисциплина КАК Дисциплина,
	|	РасписаниеЗанятий.Преподаватель КАК Преподаватель,
	|	РасписаниеЗанятий.Аудитория КАК Аудитория,
	|	РасписаниеЗанятий.ВидЗанятия КАК ВидЗанятия,
	|	РасписаниеЗанятий.ДеньНедели КАК ДеньНедели,
	|	РасписаниеЗанятий.НомерПары КАК НомерПары,
	|	РасписаниеЗанятий.ВремяНачала КАК ВремяНачала,
	|	РасписаниеЗанятий.ВремяОкончания КАК ВремяОкончания
	|ИЗ
	|	РегистрСведений.РасписаниеЗанятий КАК РасписаниеЗанятий";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СтрокаРасписания = Новый Структура;
		СтрокаРасписания.Вставить("group", Строка(Выборка.УчебнаяГруппа));
		СтрокаРасписания.Вставить("discipline", Строка(Выборка.Дисциплина));
		СтрокаРасписания.Вставить("teacher", Строка(Выборка.Преподаватель));
		СтрокаРасписания.Вставить("classroom", Строка(Выборка.Аудитория));
		СтрокаРасписания.Вставить("lesson_type", Строка(Выборка.ВидЗанятия));
		СтрокаРасписания.Вставить("day_of_week", Выборка.ДеньНедели);
		СтрокаРасписания.Вставить("lesson_number", Выборка.НомерПары);
		СтрокаРасписания.Вставить("time_start", Формат(Выборка.ВремяНачала, "ДФ=HH:mm"));
		СтрокаРасписания.Вставить("time_end", Формат(Выборка.ВремяОкончания, "ДФ=HH:mm"));
		
		МассивРасписания.Добавить(СтрокаРасписания);
		
	КонецЦикла;
	
	Возврат МассивРасписания;
	
КонецФункции