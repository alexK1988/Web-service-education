Функция ДоступРазрешен(HTTPЗапрос) Экспорт
	
	Если НЕ Константы.ИспользоватьАвторизациюAPI.Получить() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Токен = ПолучитьТокенИзЗапроса(HTTPЗапрос);
	
	Если ПустаяСтрока(Токен) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ТокенЗарегистрирован(Токен);
	
КонецФункции

Функция ПолучитьТокенИзЗапроса(HTTPЗапрос) Экспорт
	
	Токен = "";
	
	Попытка
		Токен = HTTPЗапрос.Заголовки.Получить("Authorization");
	Исключение
		Токен = "";
	КонецПопытки;
	
	Если ПустаяСтрока(Токен) Тогда
		Попытка
			Токен = HTTPЗапрос.ПараметрыЗапроса.Получить("token");
		Исключение
			Токен = "";
		КонецПопытки;
	КонецЕсли;
	
	Если СтрНачинаетсяС(Токен, "Bearer ") Тогда
		Токен = Сред(Токен, 8);
	КонецЕсли;
	
	Возврат Токен;
	
КонецФункции

Функция ТокенЗарегистрирован(Токен) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НастройкиДоступаAPI.ВнешняяСистема КАК ВнешняяСистема
	|ИЗ
	|	РегистрСведений.НастройкиДоступаAPI КАК НастройкиДоступаAPI
	|ГДЕ
	|	НастройкиДоступаAPI.ТокенДоступа = &Токен
	|	И НастройкиДоступаAPI.Активна = ИСТИНА
	|	И НастройкиДоступаAPI.РазрешитьЧтение = ИСТИНА";
	
	Запрос.УстановитьПараметр("Токен", Токен);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат Результат.Следующий();
	
КонецФункции