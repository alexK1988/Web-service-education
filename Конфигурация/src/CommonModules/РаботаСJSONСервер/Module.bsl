Функция СформироватьУспешныйОтвет(Данные = Неопределено) Экспорт
	
	Ответ = Новый Структура;
	Ответ.Вставить("success", Истина);
	
	Если Данные = Неопределено Тогда
		Ответ.Вставить("data", Новый Структура);
	Иначе
		Ответ.Вставить("data", Данные);
	КонецЕсли;
	
	Возврат СформироватьJSON(Ответ);
	
КонецФункции

Функция СформироватьОтветСОшибкой(ТекстОшибки, КодОшибки = 400) Экспорт
	
	Ответ = Новый Структура;
	Ответ.Вставить("success", Ложь);
	Ответ.Вставить("code", КодОшибки);
	Ответ.Вставить("error", ТекстОшибки);
	
	Возврат СформироватьJSON(Ответ);
	
КонецФункции

Функция СформироватьJSON(Данные) Экспорт
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	ЗаписатьJSON(ЗаписьJSON, Данные);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция ПрочитатьJSONИзСтроки(СтрокаJSON) Экспорт
	
	Если ПустаяСтрока(СтрокаJSON) Тогда
		Возврат Новый Структура;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Попытка
		Данные = ПрочитатьJSON(ЧтениеJSON);
	Исключение
		Данные = Новый Структура;
	КонецПопытки;
	
	ЧтениеJSON.Закрыть();
	
	Возврат Данные;
	
КонецФункции

Функция СоздатьЭлементМассива(СоответствиеДанных) Экспорт
	
	Элемент = Новый Структура;
	
	Для Каждого Параметр Из СоответствиеДанных Цикл
		Элемент.Вставить(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	
	Возврат Элемент;
	
КонецФункции